{
  "name": "video-editor",
  "version": "0.2.0",
  "private": true,
  "description": "CapCut 유사 데스크톱 영상 편집기",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "npm run build && playwright test",
    "progress": "node scripts/progress.mjs",
    "progress:next": "node scripts/progress.mjs --next",
    "progress:all": "node scripts/progress.mjs --all",
    "plan:validate": "node scripts/validate-plan.mjs",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "mp4box": "^0.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/dom-webcodecs": "^0.1.15",
    "@types/ffprobe-static": "^2.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.0",
    "eslint": "^9.29.0",
    "prettier": "^3.6.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "author": "mark@vessl.ai",
  "license": "UNLICENSED"
}
